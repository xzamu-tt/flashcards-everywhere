<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Flashcards Everywhere</string>

    <!-- Onboarding -->
    <string name="onboarding_title">Your phone is the deck</string>
    <string name="onboarding_subtitle">Cards reach you everywhere — notifications, widgets, the lockscreen, every app.</string>
    <string name="onboarding_continue">Continue</string>

    <!-- Permissions -->
    <string name="perm_anki_title">Connect to AnkiDroid</string>
    <string name="perm_anki_body">We read your due cards from AnkiDroid and submit reviews back. AnkiDroid stays in charge of your collection and AnkiWeb sync.</string>
    <string name="perm_notifications_title">Notifications</string>
    <string name="perm_notifications_body">We deliver cards through notifications. Without this, the most useful surface is silent.</string>
    <string name="perm_usage_title">Usage access</string>
    <string name="perm_usage_body">Lets us count screen-on time and pace cards toward your daily goal. Stays on-device.</string>
    <string name="perm_fullscreen_title">Lockscreen cards</string>
    <string name="perm_fullscreen_body">Lets a card appear above the lockscreen so you can review without unlocking.</string>
    <string name="perm_overlay_title">Display over other apps</string>
    <string name="perm_overlay_body">Required to show a card on top of any app you open.</string>
    <string name="perm_a11y_title">Accessibility service</string>
    <string name="perm_a11y_body">Required to detect when you open an app and surface the overlay instantly. Used solely for flashcard delivery.</string>

